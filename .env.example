# Copy this file to .env and fill in the values.

# Where the app listens
PORT=5000

# MongoDB connection string (local Mongo or an Atlas cluster)
MONGODB_URI=mongodb://127.0.0.1:27017/safecircle

# Long random string used to sign auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# The origin(s) your frontend is served from, comma-separated.
# Vite's default dev server runs on 5173.
CLIENT_ORIGIN=http://localhost:5173

# --- Optional: push notifications ---
# Only needed if you want the server to actually SEND push notifications
# (via Firebase Cloud Messaging) when an SOS is triggered. Without this,
# FCM tokens are still stored, they just won't be used to send anything.
# Get this JSON from Firebase Console -> Project settings -> Service
# accounts -> Generate new private key. Paste the whole thing on one line.
FIREBASE_SERVICE_ACCOUNT_JSON=
